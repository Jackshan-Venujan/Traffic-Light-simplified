<mxfile host="app.diagrams.net" modified="2026-05-31T00:00:00.000Z" agent="Claude" version="21.7.5">
  <diagram id="yolov8-arch" name="YOLOv8s Architecture">
    <mxGraphModel dx="1400" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="680" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="YOLOv8s Architecture for Traffic Light Detection"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=17;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1200" height="45" as="geometry" />
        </mxCell>

        <!-- ── Block 1: Input ── -->
        <mxCell id="3"
          value="&lt;b&gt;INPUT&lt;/b&gt;&lt;br&gt;&lt;br&gt;1280 &amp;times; 1280 &amp;times; 3&lt;br&gt;RGB Image&lt;br&gt;&lt;br&gt;(resized from&lt;br&gt;1280 &amp;times; 960)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="130" width="155" height="200" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="4" value="" style="endArrow=block;endFill=1;strokeWidth=2;"
          edge="1" source="3" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Block 2: Backbone ── -->
        <mxCell id="5"
          value="&lt;b&gt;BACKBONE&lt;/b&gt;&lt;br&gt;CSP DarkNet + C2f Blocks&lt;br&gt;&lt;br&gt;&amp;bull; Conv Stem (Layer 0)&lt;br&gt;&amp;bull; C2f Block &amp;times; 2 (Layers 1–4)&lt;br&gt;&amp;bull; C2f Block &amp;times; 4 (Layers 5–6)&lt;br&gt;&amp;bull; C2f Block &amp;times; 4 (Layers 7–8)&lt;br&gt;&amp;bull; SPPF Pooling (Layer 9)&lt;br&gt;&lt;br&gt;Extracts hierarchical&lt;br&gt;spatial features at&lt;br&gt;multiple resolutions"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="210" y="80" width="240" height="300" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="6" value="" style="endArrow=block;endFill=1;strokeWidth=2;"
          edge="1" source="5" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Block 3: Neck ── -->
        <mxCell id="7"
          value="&lt;b&gt;NECK&lt;/b&gt;&lt;br&gt;FPN + PAN&lt;br&gt;&lt;br&gt;&amp;bull; Feature Pyramid Network:&lt;br&gt;  top-down upsampling&lt;br&gt;  (fuses deep + shallow features)&lt;br&gt;&amp;bull; Path Aggregation Network:&lt;br&gt;  bottom-up downsampling&lt;br&gt;&lt;br&gt;Outputs 3 feature maps:&lt;br&gt;&amp;bull; 80 &amp;times; 80 (small objects)&lt;br&gt;&amp;bull; 40 &amp;times; 40 (medium objects)&lt;br&gt;&amp;bull; 20 &amp;times; 20 (large objects)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="240" height="300" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="8" value="" style="endArrow=block;endFill=1;strokeWidth=2;"
          edge="1" source="7" target="9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Block 4: Detection Head ── -->
        <mxCell id="9"
          value="&lt;b&gt;DETECTION HEAD&lt;/b&gt;&lt;br&gt;Decoupled Anchors-Free Head&lt;br&gt;&lt;br&gt;3 parallel heads:&lt;br&gt;&amp;bull; Head 1 (80&amp;times;80): small&lt;br&gt;&amp;bull; Head 2 (40&amp;times;40): medium&lt;br&gt;&amp;bull; Head 3 (20&amp;times;20): large&lt;br&gt;&lt;br&gt;Each head predicts:&lt;br&gt;&amp;bull; Box offset (DFL loss)&lt;br&gt;&amp;bull; Class probability (BCE)&lt;br&gt;&amp;bull; Objectness score&lt;br&gt;&lt;br&gt;(Replaced from COCO&lt;br&gt;80-class to 3-class head)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="750" y="80" width="240" height="300" as="geometry" />
        </mxCell>

        <!-- Arrow 4→5 -->
        <mxCell id="10" value="" style="endArrow=block;endFill=1;strokeWidth=2;"
          edge="1" source="9" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Block 5: NMS + Output ── -->
        <mxCell id="11"
          value="&lt;b&gt;NMS&lt;/b&gt;&lt;br&gt;Non-Maximum Suppression&lt;br&gt;&lt;br&gt;Removes overlapping&lt;br&gt;duplicate boxes&lt;br&gt;&lt;br&gt;&lt;hr/&gt;&lt;b&gt;OUTPUT&lt;/b&gt;&lt;br&gt;&lt;br&gt;Bounding boxes&lt;br&gt;+ class labels:&lt;br&gt;&amp;bull; go&lt;br&gt;&amp;bull; stop&lt;br&gt;&amp;bull; warning&lt;br&gt;&lt;br&gt;+ confidence score"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="180" height="260" as="geometry" />
        </mxCell>

        <!-- Stats bar -->
        <mxCell id="12"
          value="YOLOv8s | 11.1M Parameters | 349 / 355 Weights Transferred from COCO Pre-training | Training Input: 1280 &amp;times; 1280"
          style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#333333;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="430" width="1170" height="40" as="geometry" />
        </mxCell>

        <!-- Sub-label: scale annotations on neck outputs -->
        <mxCell id="13" value="80&amp;times;80"
          style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=center;fontSize=9;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="490" y="390" width="60" height="22" as="geometry" />
        </mxCell>
        <mxCell id="14" value="40&amp;times;40"
          style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=center;fontSize=9;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="570" y="390" width="60" height="22" as="geometry" />
        </mxCell>
        <mxCell id="15" value="20&amp;times;20"
          style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=center;fontSize=9;rounded=1;"
          vertex="1" parent="1">
          <mxGeometry x="648" y="390" width="60" height="22" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
