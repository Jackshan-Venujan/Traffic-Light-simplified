          vertex="1" parent="1">
          <mxGeometry x="780" y="165" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="24"
          value="&lt;b&gt;Clip 3&lt;/b&gt;&lt;br&gt;~300 frames&lt;br&gt;F001 – F300&lt;br&gt;&lt;br&gt;TRAIN"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="910" y="165" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="25" value="..."
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1030" y="190" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="26"
          value="&lt;b&gt;Clip N&lt;/b&gt;&lt;br&gt;~300 frames&lt;br&gt;F001 – F300&lt;br&gt;&lt;br&gt;VAL"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="1100" y="165" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 85 / 15 labels -->
        <mxCell id="27" value="85% of clips → TRAIN SET"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=11;fontColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="252" width="430" height="25" as="geometry" />
        </mxCell>
        <mxCell id="28" value="15% → VAL"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=11;fontColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="1080" y="252" width="140" height="25" as="geometry" />
        </mxCell>

        <!-- Success explanation -->
        <mxCell id="29"
          value="&#10004; SOLUTION: Entire sequences are kept together. No frame from Clip N ever appears in the training set. The model is evaluated on footage it has never seen in any form — genuine generalisation. This is the correct approach for sequential video data."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="285" width="620" height="73" as="geometry" />
        </mxCell>

        <!-- Result (correct) -->
        <mxCell id="30" value="Result: Validation mAP reflects true generalisation. No leakage between consecutive frames."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=2;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="373" width="620" height="40" as="geometry" />
        </mxCell>

        <!-- Bottom summary note -->
        <mxCell id="31"
          value="Implementation: Clips are identified from filename prefix (e.g. dayClip1, daySequence2). 85% of unique clip names are assigned to train; the remaining 15% form the validation set. Symlinks preserve disk space."
          style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#333333;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="435" width="1240" height="40" as="geometry" />
        </mxCell>

