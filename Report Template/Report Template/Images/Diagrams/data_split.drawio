        <!-- Legend -->
        <mxCell id="13" value=""
          style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="237" width="16" height="16" as="geometry" />
