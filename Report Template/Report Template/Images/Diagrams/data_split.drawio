  <diagram id="data-split" name="Data Split Strategy">
    <mxGraphModel dx="1300" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="650" math="0" shadow="0">
