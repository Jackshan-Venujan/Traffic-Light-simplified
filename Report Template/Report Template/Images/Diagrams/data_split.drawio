        <mxCell id="15" value=""
          style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="115" y="237" width="16" height="16" as="geometry" />
        </mxCell>
        <mxCell id="16" value="Validation"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="137" y="235" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Problem explanation box -->
        <mxCell id="17"
          value="&#9888; PROBLEM: Consecutive frames are nearly identical images — the traffic light barely moves between F001, F002, F003. When these frames are randomly split, the model sees training images that look almost exactly like its validation images. Validation accuracy is artificially inflated (data leakage). The model has not truly generalised."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="268" width="570" height="90" as="geometry" />
        </mxCell>

        <!-- Result (wrong) -->
        <mxCell id="18" value="Result: Validation mAP appears high but the model fails on truly unseen footage."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=2;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="373" width="570" height="40" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════ -->
        <!-- Divider -->
        <!-- ══════════════════════════════════════════ -->
        <mxCell id="19" value=""
          style="line;strokeWidth=2;strokeColor=#666666;dashed=1;fillColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="626" y="65" width="10" height="360" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════ -->
        <!-- RIGHT PANEL — Correct (sequence-level) -->
        <!-- ══════════════════════════════════════════ -->

        <!-- Green title box -->
        <mxCell id="20" value="&#10004; CORRECT: Sequence-Level Split"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="75" width="620" height="45" as="geometry" />
        </mxCell>

        <!-- All clips label -->
        <mxCell id="21" value="All clips in the dataset are assigned as complete units — no frame from a clip is split across sets"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="650" y="133" width="620" height="25" as="geometry" />
        </mxCell>

        <!-- Clip boxes -->
        <mxCell id="22"
          value="&lt;b&gt;Clip 1&lt;/b&gt;&lt;br&gt;~300 frames&lt;br&gt;F001 – F300&lt;br&gt;&lt;br&gt;TRAIN"
